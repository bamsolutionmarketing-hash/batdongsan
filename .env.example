# Supabase — copy to .env.local and fill from your Supabase project settings.
# (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose to the browser. (Project Settings -> API -> service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Base URL the upload action uses to reach the Python extractor (/api/extract).
# On Vercel this is the same origin and can be left blank. For local dev where
# Python isn't running next to Next, point this at a running extractor.
EXTRACTOR_URL=
NEXT_PUBLIC_SITE_URL=
